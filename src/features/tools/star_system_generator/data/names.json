{
  "_notes": {
    "file": "Name-building pools for systems, bodies, moons, catalog labels, and settlement names.",
    "editing": "Names should be short, pronounceable at the table, and tonally consistent with frontier sci-fi. Descriptor rules are matched by keyword in generated settlement facts.",
    "sections": {
      "systemNameCores": "Root words for generated star-system names. Keep entries single-word so every naming pattern, including glued compound names, stays readable.",
      "systemNameForms": "Second words for compound, possessive, and route-style system names.",
      "systemNamePatterns": "Allowed system-name construction patterns used by code.",
      "systemCatalogLabels": "Catalog prefixes for less poetic system names.",
      "bodyNameCores": "Retired root words for future optional local aliases. Canonical generated bodies use designation-first names.",
      "bodyNameFormsByCategory": "Retired category-specific body-name suffix pools for future optional local aliases.",
      "moonNameCores": "Retired root words for future optional moon aliases. Canonical generated moons use designation-first names.",
      "moonNameForms": "Retired moon-name suffix pools for future optional local aliases.",
      "settlementNameDescriptors": "Rule-backed descriptors used to name settlements from function, category, authority, and scale."
    }
  },
